# DATABASE
DATABASE_URL=postgresql://username:password@localhost:5432/internreach

# APOLLO
APOLLO_API_KEY=your_apollo_api_key_here

# GMAIL OAUTH
GMAIL_CLIENT_ID=your_google_client_id
GMAIL_CLIENT_SECRET=your_google_client_secret
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# AZURE OPENAI
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_LLM_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_KEY=your_azure_openai_key

# AUTH
JWT_SECRET_KEY=change-me-in-production-use-a-real-secret

# REDIS
REDIS_URL=redis://localhost:6379/0

# FRONTEND
FRONTEND_URL=http://localhost:3000
